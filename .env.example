# Local secrets — copy to .env (never commit .env)

# --- Postgres (Neon) — required for ingest/alerts/MCP after migration ---
# Full URI from Neon Console → Connect → Connection string
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# --- Email alerts (Gmail app password) ---
ALERT_EMAIL_TO=you@gmail.com
ALERT_EMAIL_FROM=you@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password

# --- Optional: CLI agent (not used by GHA ingest/alert) ---
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# --- Day01 bootcamp only ---
WAREHOUSE_PATH=data/warehouse.duckdb
SQL_ROW_LIMIT=500

# --- Google Flights ingest (Playwright) ---
# GOOGLE_HEADLESS=false
# GOOGLE_FETCH_PAUSE_SECONDS=3
